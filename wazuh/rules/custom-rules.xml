<!-- ============================================================
     Custom Wazuh Detection Rules - DevSecOps Pipeline
     Maps to: Threat Model (D1) STRIDE threats A-T-001, A-S-001, A-T-002
     ============================================================ -->

<group name="devsecops,flask,">

  <rule id="100001" level="10">
    <regex>OperationalError|ProgrammingError|UNION SELECT|syntax error|unrecognized token|no such column</regex>
    <description>Possible SQL injection attempt detected in Flask application logs</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>attack,sql_injection,web,</group>
  </rule>

  <rule id="100002" level="3">
    <regex>WARNING:tornado.access:401|WARNING:tornado.access:404 POST /login</regex>
    <description>Authentication failure in Flask application logs</description>
    <group>authentication_failed,web,</group>
  </rule>

  <rule id="100003" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100002</if_matched_sid>
    <description>Possible brute force attack - 5 or more auth failures in 60 seconds</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>attack,authentication_failed,brute_force,web,</group>
  </rule>

  <rule id="100004" level="12">
    <regex>pickle\.loads|deserializ|Unpickling|500 POST /api/deserialize</regex>
    <description>Pickle deserialization invoked at runtime - possible RCE attempt</description>
    <mitre>
      <id>T1059.006</id>
    </mitre>
    <group>attack,deserialization,rce,</group>
  </rule>

</group>
